{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "guidelines/**",
              "ui_kits/big_dog_board/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Albert Sans|Geist))/i]",
        "message": "Font not provided by the design system. Available: Albert Sans, Geist."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|block|disabled|iconLeft|iconRight|as|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, block, disabled, iconLeft, iconRight, as, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|brand|action|soft|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'brand' | 'action' | 'soft' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:button|a)$/]",
        "message": "<Button> as must be one of 'button' | 'a'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|dot|solid|children|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: tone, dot, solid, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:ink|yellow|blue|green|orange|red|violet)$/]",
        "message": "<Chip> tone must be one of 'ink' | 'yellow' | 'blue' | 'green' | 'orange' | 'red' | 'violet'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Field'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|accent|key|ref|className|style|children)$/]",
        "message": "<Field> doesn't accept that prop. Declared props: label, accent."
      },
      {
        "selector": "JSXOpeningElement[name.name='Field'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:none|blue|green|red|violet|yellow|orange)$/]",
        "message": "<Field> accent must be one of 'none' | 'blue' | 'green' | 'red' | 'violet' | 'yellow' | 'orange'."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|active|icon|onClick|className|key|ref|className|style|children)$/]",
        "message": "<NavItem> doesn't accept that prop. Declared props: label, active, icon, onClick, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Panel'] > JSXAttribute > JSXIdentifier[name!=/^(?:accent|border|padding|title|subtitle|children|key|ref|className|style|children)$/]",
        "message": "<Panel> doesn't accept that prop. Declared props: accent, border, padding, title, subtitle, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Panel'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:none|yellow|blue|green|orange|red|violet|ink)$/]",
        "message": "<Panel> accent must be one of 'none' | 'yellow' | 'blue' | 'green' | 'orange' | 'red' | 'violet' | 'ink'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Panel'] > JSXAttribute[name.name='border'] > Literal[value!=/^(?:none|hairline|strong)$/]",
        "message": "<Panel> border must be one of 'none' | 'hairline' | 'strong'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ToolButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:active|label|title|onClick|className|style|key|ref|className|style|children)$/]",
        "message": "<ToolButton> doesn't accept that prop. Declared props: active, label, title, onClick, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ToolCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|label|meta|icon|onOpen|className|style|key|ref|className|style|children)$/]",
        "message": "<ToolCard> doesn't accept that prop. Declared props: tone, label, meta, icon, onOpen, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ToolCard'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:blue|green|violet|red|orange|yellow|ink)$/]",
        "message": "<ToolCard> tone must be one of 'blue' | 'green' | 'violet' | 'red' | 'orange' | 'yellow' | 'ink'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
